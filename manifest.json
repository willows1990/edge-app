/* PATCH v1.2.9 - star save row + compact expandable data + smoother motion */
.save-star-button {
  width: 36px !important;
  height: 36px !important;
  min-width: 36px !important;
  font-size: 25px !important;
  border-radius: 10px !important;
  color: rgba(150, 164, 184, 0.78) !important;
  transition:
    color 0.22s ease,
    transform 0.22s ease,
    text-shadow 0.22s ease,
    background 0.22s ease,
    opacity 0.22s ease !important;
}

.save-star-button.saved {
  color: #ffe680 !important;
  text-shadow: 0 0 12px rgba(255, 230, 128, 0.34) !important;
}

.save-star-button:hover,
.save-star-button:focus-visible {
  background: rgba(255,255,255,0.035) !important;
}

.save-star-button:active,
.save-star-button.saved:active {
  transform: scale(0.88) !important;
}

/* Expanded horse details now size to their data rather than filling the full card. */
.card .more.market-more,
.card .more.selection-more {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) !important;
  width: 62% !important;
  min-width: 214px !important;
  max-width: 260px !important;
  margin: 0 0 0 48px !important;
  padding: 0 10px !important;
  min-height: 0 !important;
  max-height: 0 !important;
  opacity: 0 !important;
  transform: translateY(-6px) scale(0.985) !important;
  overflow: hidden !important;
  pointer-events: none !important;
  transition:
    max-height 0.26s ease,
    opacity 0.22s ease,
    transform 0.24s ease,
    padding 0.24s ease,
    margin 0.24s ease !important;
}

.card.open .more.market-more,
.card.open .more.selection-more {
  max-height: 112px !important;
  opacity: 1 !important;
  transform: translateY(0) scale(1) !important;
  padding: 8px 10px !important;
  margin: 0 0 8px 48px !important;
  pointer-events: auto !important;
}

.card .more.market-more .more-data,
.card .more.selection-more .more-data {
  justify-self: center !important;
  width: 192px !important;
  max-width: 100% !important;
  grid-template-columns: 88px 88px !important;
  column-gap: 16px !important;
}

.card .more.market-more .more-col,
.card .more.selection-more .more-col {
  width: 88px !important;
  max-width: 88px !important;
}

.card {
  transition:
    background 0.24s ease,
    border-color 0.24s ease,
    box-shadow 0.24s ease,
    transform 0.24s ease !important;
}

.runner,
.source-group-header,
.filters-panel,
.filters,
.selection-group-body {
  transition:
    opacity 0.24s ease,
    transform 0.24s ease,
    max-height 0.28s ease,
    background 0.24s ease,
    border-color 0.24s ease !important;
}

/* Selections groups: closed by default in JS, but reopen smoothly once toggled. */
.selection-group-body {
  overflow: hidden !important;
  opacity: 1 !important;
  transform: translateY(0) !important;
}

.selection-group-body.is-closed {
  display: none !important;
}

@media (max-width: 390px) {
  .save-star-button {
    width: 34px !important;
    height: 34px !important;
    min-width: 34px !important;
    font-size: 24px !important;
  }

  .card .more.market-more,
  .card .more.selection-more {
    width: 64% !important;
    min-width: 202px !important;
    max-width: 238px !important;
    margin-left: 42px !important;
  }

  .card.open .more.market-more,
  .card.open .more.selection-more {
    margin-left: 42px !important;
  }

  .card .more.market-more .more-data,
  .card .more.selection-more .more-data {
    width: 178px !important;
    grid-template-columns: 81px 81px !important;
    column-gap: 14px !important;
  }

  .card .more.market-more .more-col,
  .card .more.selection-more .more-col {
    width: 81px !important;
    max-width: 81px !important;
