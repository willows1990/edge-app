/* PATCH v1.2.1 - Market controls row + filters panel fix */
.market-controls-row {
  display: grid !important;
  grid-template-columns: 7fr 3fr !important;
  gap: 10px !important;
  align-items: stretch !important;
  margin-bottom: 14px !important;
}

.market-controls-row .edge-shell,
.market-controls-row .filters-shell {
  margin-bottom: 0 !important;
  min-height: 80px !important;
}

.market-controls-row .edge-shell {
  display: grid !important;
  grid-template-columns: 70px minmax(0, 1fr) !important;
  align-items: center !important;
  gap: 10px !important;
}

.market-controls-row .filters-shell {
  display: flex !important;
  align-items: stretch !important;
  overflow: hidden !important;
}

.market-controls-row .filters-toggle {
  width: 100% !important;
  height: 100% !important;
  padding: 0 16px !important;
  justify-content: center !important;
  gap: 8px !important;
  white-space: nowrap !important;
}

.market-controls-row .filters-toggle span {
  margin-left: 2px !important;
}

.filters-panel {
  display: none !important;
  grid-column: 1 / -1 !important;
  grid-template-columns: 1fr 1fr !important;
  gap: 12px !important;
  padding: 14px !important;
  border: 1px solid var(--line) !important;
  border-radius: 14px !important;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.095) 0%, rgba(255,255,255,0.035) 42%, rgba(255,255,255,0.012) 100%),
    rgba(8, 24, 38, 0.34) !important;
  backdrop-filter: blur(25px) saturate(155%) brightness(1.06) !important;
  -webkit-backdrop-filter: blur(25px) saturate(155%) brightness(1.06) !important;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.15),
    inset 0 -1px 0 rgba(255,255,255,0.04),
    0 12px 34px rgba(0,0,0,0.16) !important;
}

.filters-panel.open {
  display: grid !important;
}

.filters-panel .field {
  min-width: 0 !important;
}

.filter-actions {
  grid-column: 1 / -1 !important;
  display: grid !important;
  grid-template-columns: 1fr 1fr !important;
  gap: 10px !important;
}

.filter-actions .clear,
.filter-actions .apply-filters {
  grid-column: auto !important;
  width: 100% !important;
  min-height: 44px !important;
}

.apply-filters:disabled {
  opacity: 0.38 !important;
  filter: grayscale(0.9) !important;
  cursor: not-allowed !important;
}

@media (max-width: 390px) {
  .market-controls-row {
    grid-template-columns: minmax(0, 7fr) minmax(104px, 3fr) !important;
    gap: 8px !important;
  }

  .market-controls-row .edge-shell {
    grid-template-columns: 50px minmax(0, 1fr) !important;
    padding: 10px !important;
  }

  .market-controls-row .filters-toggle {
    padding: 0 10px !important;
    font-size: 14px !important;
  }

  .filters-panel {
    grid-template-columns: 1fr !important;
    gap: 10px !important;
  }
}


/* PATCH v1.2.2 - compact market controls + staged filters */
.market-controls-row .edge-shell,
.market-controls-row .filters-shell {
  min-height: 58px !important;
