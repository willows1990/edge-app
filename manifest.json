  <script>
    const SHEET_DOC_ID = "1mb96Dt3QKUn8WFrWcz2Bs2LSgFTRK6UqEzCjp-hn-wM";
    const SHEET_BASE_URL = `https://docs.google.com/spreadsheets/d/${SHEET_DOC_ID}`;

    const MARKET_FEEDS = {
