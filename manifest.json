/* PATCH - collapsible Selections source groups */
.source-group-header.selection-source-toggle {
  cursor: pointer !important;
  user-select: none !important;
  justify-content: flex-start !important;
}
.selection-group-count {
  margin-left: auto !important;
  color: var(--muted) !important;
  font-size: 10.5px !important;
  font-weight: 700 !important;
  white-space: nowrap !important;
  padding: 2px 2px 2px 8px !important;
}
.selection-group-chevron {
  color: var(--muted) !important;
  font-size: 14px !important;
  font-weight: 800 !important;
  line-height: 1 !important;
  margin-left: 4px !important;
  transform: rotate(90deg);
  transition: transform .18s ease, color .18s ease;
}
.selection-source-toggle.is-closed .selection-group-chevron {
  transform: rotate(0deg);
}
.selection-group-body {
  display: block;
}
.selection-group-body.is-closed {
  display: none !important;
}


