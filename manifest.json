<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Racing Edge</title>
  <!-- PWA support -->
  <meta name="theme-color" content="#061017" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Racing Edge" />
  <link rel="manifest" href="manifest.json" />
  <link rel="apple-touch-icon" href="icons/edge-horse-v2-192.png" />

  <style>
    :root {
      --bg: #061017;
      --panel: #0b1822;
      --panel2: #102230;
      --line: #1e3445;
      --text: #f2f7fb;
      --muted: #90a4b8;
      --green: #56e36d;
      --blue: #3388ff;
      --orange: #ffad33;
      --pink: #ff6685;
      --purple: #b477ff;
    }

    * { box-sizing: border-box; }

    html {
      background:
        radial-gradient(circle at top left, rgba(39, 112, 180, 0.15), transparent 35%),
        radial-gradient(circle at bottom right, rgba(72, 255, 118, 0.08), transparent 35%),
        var(--bg);
    }

    body {
      margin: 0;
      font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(39, 112, 180, 0.15), transparent 35%),
        radial-gradient(circle at bottom right, rgba(72, 255, 118, 0.08), transparent 35%),
        var(--bg);
      color: var(--text);
      max-width: 480px;
      margin-inline: auto;
      min-height: 100vh;
      padding-top: env(safe-area-inset-top, 0px);
      padding-bottom: calc(104px + env(safe-area-inset-bottom, 0px));
    }

    .app {
      padding: 18px 14px 0;
    }

    .topbar {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: stretch;
      gap: 10px;
      margin-bottom: 14px;
    }

    .book-select {
      width: 100%;
      height: 58px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: rgba(15, 34, 48, 0.8);
      color: var(--text);
      font-size: 18px;
      font-weight: 600;
      outline: none;
      appearance: none;
      padding: 0 36px 0 13px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .title-wrap {
      position: relative;
      min-width: 0;
    }

    .title-wrap::after { content: ""; }


    .right-tools {
      display: flex;
      align-items: stretch;
      gap: 8px;
    }

    .stat-card {
      display: flex;
      align-items: center;
      gap: 14px;
      background: rgba(15, 34, 48, 0.8);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 7px 10px;
      height: 58px;
    }

    .stat strong {
      display: block;
      font-size: 20px;
      line-height: 1;
      font-weight: 600;
    }

    .stat span {
      display: block;
      color: var(--muted);
      font-size: 12px;
      margin-top: 3px;
    }

    .stat.blue strong { color: #86b7f2; }
    .stat.green strong { color: #8fd7a2; }

    .icon-btn {
      width: 44px;
      height: 58px;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: rgba(15, 34, 48, 0.8);
      color: var(--text);
      font-size: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
    }


    .edge-shell {
      display: grid;
      grid-template-columns: 52px minmax(0, 1fr);
      align-items: center;
      gap: 10px;
      border: 1px solid var(--line);
      background: rgba(6, 18, 30, 0.86);
      border-radius: 13px;
      margin-bottom: 10px;
      padding: 10px 12px;
    }

    .edge-shell label {
      color: var(--muted);
      font-size: 12px;
      font-weight: 400;
    }

    .edge-shell select {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 9px;
      background: rgba(10, 27, 43, 0.96);
      color: var(--text);
      font-size: 13px;
      font-weight: 400;
      padding: 8px 10px;
      outline: none;
    }

    .more {
      display: none;
      grid-template-columns: 30px minmax(0, 1fr) minmax(0, 1fr);
      align-items: stretch;
      column-gap: 5px;
      margin: 0 6px 7px 24px;
      padding: 6px;
      border-radius: 10px;
      background: rgba(7, 22, 36, 0.50);
      border: 1px solid rgba(105, 190, 255, 0.22);
      width: calc(100% - 30px);
      min-height: 82px;
    }

    

    

    .screen {
      display: none;
    }

    .screen.active {
      display: block;
    }

    .empty-state {
      color: var(--muted);
      border: 1px solid var(--line);
      background: rgba(6, 18, 30, 0.86);
      border-radius: 13px;
      padding: 16px;
      font-size: 13px;
      text-align: center;
      margin-top: 12px;
    }




    .book-select,
    .stat-card,
    .icon-btn,
    .filters-shell,
    .edge-shell,
    .card,
    .more,
    .bottom-nav,
    .field input,
    .field select,
    .edge-shell select {
      background-color: rgba(10, 27, 43, 0.46) !important;
      backdrop-filter: blur(18px) saturate(135%);
      -webkit-backdrop-filter: blur(18px) saturate(135%);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.105),
        inset 0 -1px 0 rgba(255, 255, 255, 0.035),
        0 10px 30px rgba(0, 0, 0, 0.18);
    }

    .card {
      border-color: rgba(105, 190, 255, 0.20);
    }

    .more {
      background-color: rgba(7, 22, 36, 0.50) !important;
      border-color: rgba(105, 190, 255, 0.22);
    }

    .updated {
      color: var(--muted);
      font-size: 13px;
      margin: 10px 2px 14px;
    }

    .filters-shell {
      border: 1px solid var(--line);
      background: rgba(8, 20, 30, 0.78);
      border-radius: 14px;
      margin-bottom: 14px;
      overflow: hidden;
    }

    .filters-toggle {
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px;
      background: transparent;
      border: 0;
      color: var(--text);
      font-size: 16px;
      font-weight: 500;
    }

    .filters {
      display: none;
      padding: 0 16px 16px;
      gap: 12px;
      grid-template-columns: 1fr 1fr;
    }

    .filters.open { display: grid; }

    .field label {
      display: block;
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 6px;
    }

    .field input, .field select {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: rgba(16, 34, 48, 0.95);
      color: var(--text);
      padding: 11px 12px;
      font-size: 15px;
      outline: none;
    }

    .clear {
      grid-column: span 2;
      border: 1px solid var(--line);
      background: transparent;
      color: var(--text);
      border-radius: 10px;
      padding: 12px;
      font-weight: 700;
    }

    .header-row, .runner {
      display: grid;
      grid-template-columns: 18px minmax(100px, 1.05fr) 66px 50px 34px 58px;
      align-items: center;
      column-gap: 11px;
      width: 100%;
    }

    .feed-scroll {
      overflow-x: hidden;
      padding-bottom: 4px;
    }

    .header-row {
      padding: 0 8px 8px;
      color: var(--text);
      font-size: 11px;
      font-weight: 700;
    }

    .card {
      background: rgba(13, 29, 41, 0.86);
      border: 1px solid rgba(30, 52, 69, 0.7);
      border-radius: 10px;
      margin-bottom: 7px;
      overflow: hidden;
      width: 100%;
    }

    .runner {
      min-height: 56px;
      padding: 0 8px;
      font-size: 12px;
    }

    .rank, .muted { color: var(--muted); }
    .horse-cell {
      line-height: 1.15;
      overflow: hidden;
      min-width: 0;
    }

    .horse {
      display: block;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: -0.01em;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .race-stack {
      line-height: 1.15;
      overflow: hidden;
      min-width: 0;
    }

    .race-time {
      display: block;
      color: var(--text);
      font-weight: 600;
      font-size: 12px;
      letter-spacing: -0.01em;
    }

    .meet-under {
      display: block;
      color: var(--muted);
      font-size: 10px;
      font-weight: 500;
      margin-top: 4px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .odds { font-weight: 700; }
    .ev, .ev-chip {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      min-width: 54px;
      height: 24px;
      border-radius: 6px;
      font-weight: 600;
      font-size: 11px;
      letter-spacing: -0.015em;
      padding: 0 4px;
    }

    .ev-grey {
      background: rgba(94, 109, 122, 0.16);
      border: 1px solid rgba(120, 135, 148, 0.24);
      color: #aeb9c2;
    }

    .ev-yellow {
      background: rgba(190, 153, 42, 0.15);
      border: 1px solid rgba(190, 153, 42, 0.24);
      color: #d8c46e;
    }

    .ev-green {
      background: rgba(63, 158, 92, 0.13);
      border: 1px solid rgba(63, 158, 92, 0.24);
      color: #8fd7a2;
    }

    .ev-purple {
      background: rgba(128, 97, 178, 0.16);
      border: 1px solid rgba(128, 97, 178, 0.26);
      color: #bca7df;
    }

    

    .ev-maroon {
      background: rgba(128, 58, 91, 0.18);
      border: 1px solid rgba(160, 75, 113, 0.28);
      color: #d99ab7;
    }

    .pt-stack {
      display: flex;
      flex-direction: column;
      gap: 3px;
      align-items: flex-start;
    }

    .pill {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      min-width: 26px;
      height: 17px;
      border-radius: 5px;
      font-size: 9.5px;
      font-weight: 600;
    }

    .p2 { background: rgba(76, 150, 215, 0.50); color: #d8ecff; }
    .p3 { background: rgba(210, 177, 65, 0.52); color: #fff0b6; }
    .p4 { background: rgba(70, 170, 112, 0.48); color: #d8f7e3; }
    .p5 { background: rgba(132, 102, 190, 0.46); color: #e2d7ff; }
    .p6 { background: rgba(184, 113, 70, 0.44); color: #f4d2bb; }
    .p7 { background: rgba(174, 87, 130, 0.44); color: #f2c5dc; }
    .term { background: rgba(43, 58, 72, 0.82); color: #d5e0e8; }
    .term-quarter { background: rgba(112, 132, 150, 0.98); color: #ffffff; }

    .more {
      display: none;
      grid-template-columns: 1fr 1fr;
      gap: 12px 18px;
      margin: 0 10px 12px 40px;
      padding: 14px;
      border-radius: 10px;
      background: rgba(5, 16, 24, 0.65);
      border: 1px solid rgba(30, 52, 69, 0.7);
    }

    .card.open .more { display: grid; }

    .more > div {
      min-width: 0;
      align-self: center;
    }

    .more h4 {
      margin: 0 0 3px;
      color: var(--muted);
      font-size: 8px;
      font-weight: 400;
      letter-spacing: .06em;
      text-align: center;
    }

    .info-row {
      display: grid;
      grid-template-columns: 21px minmax(0, 1fr);
      align-items: center;
      gap: 3px;
      font-size: 8.8px;
      margin: 2px 0;
    }

    .info-row strong:not(.ev-chip) {
      min-height: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 500;
      text-align: center;
      font-size: 9px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .more .ev-chip {
      min-width: 39px;
      height: 18px;
      font-size: 8.8px;
      padding: 0 2px;
      border-radius: 5px;
    }


    

    

    

    

    


    

    .save-horse {
      grid-column: 1;
      grid-row: 1;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(10, 27, 43, 0.56);
      color: var(--text);
      font-size: 8.5px;
      font-weight: 400;
      padding: 4px 2px;
      text-align: center;
      min-height: 68px;
      min-width: 28px;
      display: flex;
      flex-direction: column;
      gap: 1px;
      align-items: center;
      justify-content: center;
      line-height: 1;
      writing-mode: horizontal-tb;
      text-orientation: mixed;
    }

    .save-horse.saved {
      border-color: rgba(216, 196, 110, 0.72);
      color: #f1df8a;
      background: rgba(190, 153, 42, 0.16);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.08);
    }

    

    

    .win-ev { color: #ffcc00; }
    .place-ev { color: var(--pink); }

    .bottom-nav {
      position: fixed;
      left: 50%;
      transform: translateX(-50%);
      bottom: 10px;
      width: min(452px, calc(100% - 28px));
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      background: rgba(13, 29, 41, 0.96);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 10px 6px;
      backdrop-filter: blur(12px);
    }

    .nav-item {
      text-align: center;
      color: var(--muted);
      font-size: 12px;
    }

    .nav-item div { font-size: 22px; margin-bottom: 3px; }
    .nav-item.active { color: var(--green); }

    @media (max-width: 420px) {
      .book-select { font-size: 16px; height: 54px; }
      .stat-card { gap: 9px; padding: 6px 8px; height: 54px; }
      .stat strong { font-size: 17px; }
      .stat span { font-size: 10px; }
      .icon-btn { width: 38px; height: 54px; }
    }

  
    /* FINAL OVERRIDES v3 - glass + balanced expanded row + saved star */
    .book-select,
    .stat-card,
    .icon-btn,
    .filters-shell,
    .edge-shell,
    .card,
    .more,
    .bottom-nav,
    .field input,
    .field select,
    .edge-shell select {
      background:
        linear-gradient(135deg, rgba(255,255,255,0.105) 0%, rgba(255,255,255,0.038) 36%, rgba(255,255,255,0.012) 100%),
        rgba(10, 27, 43, 0.30) !important;
      backdrop-filter: blur(25px) saturate(155%) brightness(1.06) !important;
      -webkit-backdrop-filter: blur(25px) saturate(155%) brightness(1.06) !important;
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.17),
        inset 0 -1px 0 rgba(255,255,255,0.045),
        0 12px 34px rgba(0,0,0,0.18) !important;
    }

    .card {
      border-color: rgba(155, 220, 255, 0.30) !important;
    }

    .more {
      display: none !important;
      grid-template-columns: 54px 128px 128px !important;
      align-items: stretch !important;
      justify-content: start !important;
      column-gap: 10px !important;
      margin: 0 8px 8px 36px !important;
      padding: 8px !important;
      border-radius: 12px !important;
      width: fit-content !important;
      max-width: calc(100% - 28px) !important;
      min-height: 82px !important;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.04) 40%, rgba(255,255,255,0.012) 100%),
        rgba(8, 24, 38, 0.34) !important;
      border: 1px solid rgba(155, 220, 255, 0.34) !important;
    }

    .card.open .more {
      display: grid !important;
    }

    .save-horse {
      grid-column: 1 !important;
      grid-row: 1 !important;
      border: 1px solid var(--line) !important;
      border-radius: 999px !important;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.12), rgba(255,255,255,0.025)),
        rgba(10, 27, 43, 0.42) !important;
      color: var(--text) !important;
      font-size: 9px !important;
      font-weight: 400 !important;
      padding: 5px 4px !important;
      text-align: center !important;
      min-height: 66px !important;
      min-width: 52px !important;
      display: flex !important;
      flex-direction: column !important;
      gap: 2px !important;
      align-items: center !important;
      justify-content: center !important;
      line-height: 1.05 !important;
      writing-mode: horizontal-tb !important;
      text-orientation: mixed !important;
      cursor: pointer !important;
    }

    .save-horse.saved {
      border-color: rgba(244, 215, 92, 0.82) !important;
      color: #ffe680 !important;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.14), rgba(255,255,255,0.028)),
        rgba(214, 170, 42, 0.24) !important;
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.14),
        0 0 14px rgba(214,170,42,0.10) !important;
    }

    .more > div {
      min-width: 0 !important;
      align-self: center !important;
      width: 128px !important;
    }

    .more h4 {
      margin: 0 0 4px !important;
      color: var(--muted) !important;
      font-size: 8.8px !important;
      font-weight: 400 !important;
      letter-spacing: .06em !important;
      text-align: center !important;
    }

    .info-row {
      display: grid !important;
      grid-template-columns: 28px minmax(0, 1fr) !important;
      align-items: center !important;
      gap: 5px !important;
      font-size: 9.7px !important;
      margin: 3px 0 !important;
    }

    .info-row strong:not(.ev-chip) {
      min-height: 18px !important;
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      font-weight: 500 !important;
      text-align: center !important;
      font-size: 10px !important;
      overflow: hidden !important;
      text-overflow: ellipsis !important;
      white-space: nowrap !important;
    }

    .more .ev-chip {
      min-width: 62px !important;
      height: 18px !important;
      font-size: 9.2px !important;
      padding: 0 3px !important;
      border-radius: 6px !important;
    }

    .horse-line {
      display: flex;
      align-items: center;
      min-width: 0;
      gap: 3px;
    }

    .saved-star {
      display: none;
      flex: 0 0 auto;
      color: #ffe680;
      font-size: 10px;
      line-height: 1;
    }

    .horse-line.is-saved .saved-star {
      display: inline-block;
    }

    .horse-line .horse {
      min-width: 0;
    }

    .ev-yellow {
      background: rgba(226, 184, 48, 0.24) !important;
      border-color: rgba(226, 184, 48, 0.40) !important;
      color: #f2dc72 !important;
    }

    .ev-green {
      background: rgba(65, 184, 106, 0.22) !important;
      border-color: rgba(65, 184, 106, 0.40) !important;
      color: #a4efb8 !important;
    }

    .ev-purple {
      background: rgba(145, 106, 210, 0.27) !important;
      border-color: rgba(145, 106, 210, 0.46) !important;
      color: #d8bfff !important;
    }

    .ev-maroon {
      background: rgba(158, 58, 106, 0.30) !important;
      border-color: rgba(194, 78, 130, 0.50) !important;
      color: #f0a4c4 !important;
    }

    .icon-btn.refresh-disabled {
      opacity: 0.36 !important;
      filter: grayscale(0.9) !important;
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.06),
        0 6px 18px rgba(0,0,0,0.12) !important;
    }

    .icon-btn.refresh-ready {
      opacity: 1 !important;
      filter: none !important;
      border-color: rgba(72, 200, 255, 0.66) !important;
      color: #7ee0ff !important;
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.12),
        0 0 0 1px rgba(72,200,255,0.14),
        0 0 16px rgba(72,200,255,0.21) !important;
    }

    @media (max-width: 390px) {
      .more {
        grid-template-columns: 48px minmax(0, 1fr) minmax(0, 1fr) !important;
        width: calc(100% - 18px) !important;
        max-width: calc(100% - 18px) !important;
        margin-left: 9px !important;
      }

      .more > div {
        width: auto !important;
      }

      .more .ev-chip {
        min-width: 54px !important;
      }
    }

  
    /* FINAL OVERRIDES v4 - full-width expanded layout + fixed saved star */
    .more {
      grid-template-columns: 52px minmax(0, 1fr) !important;
      grid-template-areas: "save data" !important;
      align-items: stretch !important;
      column-gap: 14px !important;
      margin: 0 8px 8px 32px !important;
      padding: 8px !important;
      width: calc(100% - 48px) !important;
      max-width: calc(100% - 48px) !important;
      min-height: 82px !important;
    }

    .save-horse {
      grid-area: save !important;
      min-width: 50px !important;
      min-height: 66px !important;
      font-size: 9px !important;
    }

    .more > div {
      width: auto !important;
      min-width: 0 !important;
      align-self: center !important;
    }

    .more > div:nth-of-type(1) {
      grid-area: data !important;
      width: auto !important;
      display: grid !important;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) !important;
      column-gap: 12px !important;
      align-items: center !important;
    }

    .more > div:nth-of-type(2) {
      display: contents !important;
    }

    .more > div:nth-of-type(1) h4,
    .more > div:nth-of-type(1) .info-row {
      grid-column: 1 !important;
    }

    .more > div:nth-of-type(2) h4,
    .more > div:nth-of-type(2) .info-row {
      grid-column: 2 !important;
    }

    .more h4 {
      font-size: 8.8px !important;
      margin-bottom: 4px !important;
    }

    .info-row {
      grid-template-columns: 28px minmax(0, 1fr) !important;
      gap: 5px !important;
      font-size: 9.5px !important;
      margin: 3px 0 !important;
