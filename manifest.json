*{
  transition:
    background-color .22s ease,
    border-color .22s ease,
    color .22s ease,
    box-shadow .22s ease,
    opacity .22s ease,
    transform .22s ease,
    max-height .28s ease;
}

.combo-card,
.fold-group,
.summary-tile,
.runner-card,
.bet-card,
button,
select,
input{
  transition:
    background-color .22s ease,
    border-color .22s ease,
    color .22s ease,
    box-shadow .22s ease,
    opacity .22s ease,
    transform .18s ease;
}

.combo-card:hover,
.summary-tile:hover,
button:hover{
  transform:translateY(-1px);
}

